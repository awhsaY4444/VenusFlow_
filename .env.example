# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Use 'db' as host when running with Docker Compose
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/venusflow

# Optional granular config (for flexibility)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgrespassword
DB_NAME=venusflow

# -----------------------------------------------------------------------------
# Security & Auth
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_a_secure_random_string
JWT_EXPIRES_IN=1d

# -----------------------------------------------------------------------------
# Google OAuth (Optional)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development